# Environments
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets
.env
*.local.yaml

# Data lake: bronze (raw fetch, regenerated fresh every run -- never
# accumulated, so nothing is lost by not persisting it) stays local-only.
# silver/gold and the SQLite app db (securities, run_metadata, and
# critically the accumulated news/sentiment history, which has no
# historical backfill source -- see features/sentiment.py) ARE committed:
# git-as-storage for the GitHub Actions nightly workflow, since Actions
# runners are ephemeral with no other persistent disk between runs. See
# "Scheduling" in README.
data/bronze/**
!data/bronze/.gitkeep

# Postgres local volume
infra/pgdata/

# Scheduled-run logs (scripts/run_nightly.ps1) -- rotated locally, not versioned
data/logs/

# MLflow
mlruns/
mlartifacts/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
