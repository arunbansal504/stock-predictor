# Copy to .env and fill in as needed. Nothing here is required for local/dev
# runs — sensible free-tier defaults are baked into common/config.py.

# --- App DB (Postgres). Leave unset to use local SQLite (./data/app.db) for dev/tests.
# DATABASE_URL=postgresql+psycopg2://stockpredictor:stockpredictor@localhost:5432/stockpredictor

# --- Analytical lake (DuckDB + Parquet). Defaults to ./data/{bronze,silver,gold}.
# LAKE_ROOT=./data

# --- Environment: dev | test | prod
# APP_ENV=dev

# --- Logging: DEBUG | INFO | WARNING | ERROR ; set LOG_JSON=true for structured logs
# LOG_LEVEL=INFO
# LOG_JSON=false

# --- Optional paid data sources (Phase 3+, not required for MVP)
# ALPHA_VANTAGE_API_KEY=
# POLYGON_API_KEY=
# FINNHUB_API_KEY=

# --- LLM (explanation-only; never used for prediction). Leave unset to disable narratives.
# LLM_API_KEY=
# LLM_MODEL=claude-sonnet-5

# --- Alerting (Phase 2+)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
